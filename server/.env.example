# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (Get this from MongoDB Atlas)
MONGO_URI=your_mongodb_connection_string

# JWT Secret Keys (Generate these randomly)
ACCESS_TOKEN_SECRET=your_long_random_string_here
REFRESH_TOKEN_SECRET=another_long_random_string_here

# Client URL (For CORS - The URL of your Vite frontend)
# Local dev: http://localhost:5173
# Production: https://your-project-name.vercel.app
CLIENT_URL=http://localhost:5173
